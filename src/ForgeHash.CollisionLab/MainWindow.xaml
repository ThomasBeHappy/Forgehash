<Window x:Class="Forgeh.CollisionLab.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ForgeHash Collision Lab"
        Height="720" Width="980"
        MinHeight="560" MinWidth="820"
        Background="{StaticResource PaperBrush}"
        Foreground="{StaticResource InkBrush}"
        FontFamily="Segoe UI"
        FontSize="13">
  <DockPanel Margin="18">
    <StackPanel DockPanel.Dock="Top">
      <TextBlock Text="ForgeHash Collision Lab" FontSize="26" FontWeight="SemiBold"/>
      <TextBlock TextWrapping="Wrap" Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}"
                 Text="Empirical uniqueness hunts against ForgeHash-B3. Not a security proof. Experimental cryptography — do not store production passwords with ForgeHash."/>
      <Border Margin="0,12,0,0" Padding="10,8" BorderBrush="{StaticResource WarnBrush}" BorderThickness="3,0,0,0" Background="#22A34D22">
        <TextBlock x:Name="WarningBanner" TextWrapping="Wrap"
                   Text="Tip: use the Development profile (8 MiB) for mass runs. Larger profiles are extremely slow."/>
      </Border>
    </StackPanel>

    <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
      <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11"
                 Text="Results are research artifacts only. A green run means no collisions in this sample set — not that collisions are impossible."/>
    </StackPanel>

    <Grid Margin="0,16,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="320"/>
        <ColumnDefinition Width="16"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Controls -->
      <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <TextBlock Text="Campaign" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <ComboBox x:Name="CampaignCombo" Height="28"/>

          <TextBlock Text="Samples (N)" FontWeight="SemiBold" Margin="0,12,0,4"/>
          <TextBox x:Name="SampleCountBox" Text="10000" Height="28" Padding="6,4"/>

          <TextBlock Text="Parameter preset" FontWeight="SemiBold" Margin="0,12,0,4"/>
          <ComboBox x:Name="PresetCombo" Height="28" SelectionChanged="PresetCombo_OnSelectionChanged"/>

          <Grid Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="8"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Memory KiB" Margin="0,0,0,2"/>
            <TextBox x:Name="MemoryBox" Grid.Row="1" Grid.Column="0" Text="8192" Height="28" Padding="6,4"/>
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Iterations" Margin="0,0,0,2"/>
            <TextBox x:Name="IterationsBox" Grid.Row="1" Grid.Column="2" Text="1" Height="28" Padding="6,4"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Parallelism" Margin="0,8,0,2"/>
            <TextBox x:Name="ParallelismBox" Grid.Row="3" Grid.Column="0" Text="1" Height="28" Padding="6,4"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="Output length" Margin="0,8,0,2"/>
            <TextBox x:Name="OutputLengthBox" Grid.Row="3" Grid.Column="2" Text="32" Height="28" Padding="6,4"/>
          </Grid>

          <TextBlock Text="Workers" FontWeight="SemiBold" Margin="0,12,0,4"/>
          <TextBox x:Name="WorkersBox" Height="28" Padding="6,4"
                   ToolTip="Concurrent sample hashes. Each worker holds a full memory matrix (~Memory KiB)."/>

          <TextBlock Text="RNG seed (optional)" FontWeight="SemiBold" Margin="0,12,0,4"/>
          <TextBox x:Name="RngSeedBox" Text="" Height="28" Padding="6,4"
                   ToolTip="Leave blank for non-deterministic Random.Shared. Used by salt/random campaigns."/>

          <CheckBox x:Name="StopOnFirstCheck" Content="Stop on first collision" Margin="0,12,0,0"/>

          <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
            <Button x:Name="StartButton" Content="Start" Width="100" Height="32" Margin="0,0,8,0" Click="StartButton_OnClick"/>
            <Button x:Name="CancelButton" Content="Cancel" Width="100" Height="32" IsEnabled="False" Click="CancelButton_OnClick"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
            <Button x:Name="ExportJsonButton" Content="Export JSON" Width="100" Height="28" Margin="0,0,8,0" IsEnabled="False" Click="ExportJsonButton_OnClick"/>
            <Button x:Name="ExportCsvButton" Content="Export CSV" Width="100" Height="28" Margin="0,0,8,0" IsEnabled="False" Click="ExportCsvButton_OnClick"/>
            <Button x:Name="ClearButton" Content="Clear" Width="72" Height="28" Click="ClearButton_OnClick"/>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>

      <!-- Results -->
      <DockPanel Grid.Column="2">
        <StackPanel DockPanel.Dock="Top">
          <ProgressBar x:Name="RunProgress" Height="10" Minimum="0" Maximum="100" Value="0"/>
          <UniformGrid Columns="4" Margin="0,10,0,0">
            <StackPanel>
              <TextBlock Text="Completed" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
              <TextBlock x:Name="CompletedText" Text="0 / 0" FontWeight="SemiBold"/>
            </StackPanel>
            <StackPanel>
              <TextBlock Text="Hashes / sec" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
              <TextBlock x:Name="RateText" Text="—" FontWeight="SemiBold"/>
            </StackPanel>
            <StackPanel>
              <TextBlock Text="Elapsed" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
              <TextBlock x:Name="ElapsedText" Text="0.0s" FontWeight="SemiBold"/>
            </StackPanel>
            <StackPanel>
              <TextBlock Text="Collisions" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
              <TextBlock x:Name="CollisionsText" Text="0" FontWeight="SemiBold"/>
            </StackPanel>
          </UniformGrid>
          <TextBlock x:Name="StatusText" Margin="0,8,0,0" Foreground="{StaticResource MutedBrush}" Text="Idle."/>
        </StackPanel>

        <Border Margin="0,12,0,0" Background="{StaticResource CodeBrush}" BorderBrush="#9AA7B5" BorderThickness="1" Padding="8">
          <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="Log" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <ListBox x:Name="LogList" BorderThickness="0" Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </DockPanel>
        </Border>
      </DockPanel>
    </Grid>
  </DockPanel>
</Window>
